        "import torch\n",
        "from transformers import GPTNeoForCausalLM, AutoTokenizer\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Clear CUDA cache\n",
        "torch.cuda.empty_cache()\n",
        "\n",
        "# Set device to CUDA if available\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "# Load model and tokenizer\n",
        "model_name = \"EleutherAI/gpt-neo-1.3B\"\n",
        "model = GPTNeoForCausalLM.from_pretrained(model_name).to(device)\n",
        "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "# Your SQL and non-SQL examples\n",
        "#sql_examples = [\"SELECT * FROM users WHERE username = 'admin' --\"]\n",
        "#non_sql_examples = [\"What is the weather like today in Oslo?\"]\n",
        "\n",
        "# Set max_length to a reasonable value\n",
        "max_length = 128  # Adjust as needed based on your data\n",
        "\n",
        "# Function to extract activations for a sentence\n",
        "def get_activations_for_sentence(sentence, model, tokenizer, max_length):\n",
        "    try:\n",
        "        input_ids = tokenizer(\n",
        "            sentence,\n",
        "            return_tensors=\"pt\",\n",
        "            padding='max_length',\n",
        "            truncation=True,\n",
        "            max_length=max_length\n",
        "        ).input_ids.to(device)\n",
        "    except Exception as e:\n",
        "        print(f\"Tokenization error: {e}\")\n",
        "        return None\n",
        "\n",
        "    print(f\"input_ids shape: {input_ids.shape}\")\n",
        "    print(f\"input_ids dtype: {input_ids.dtype}\")\n",
        "    print(f\"input_ids: {input_ids}\")\n",
        "    print(f\"Max token ID: {input_ids.max().item()}\")\n",
        "    print(f\"Min token ID: {input_ids.min().item()}\")\n",
        "    print(f\"Tokenizer vocab size: {tokenizer.vocab_size}\")\n",
        "\n",
        "    if input_ids.max() >= tokenizer.vocab_size or input_ids.min() < 0:\n",
        "        raise ValueError(\"Invalid token IDs detected in input_ids.\")\n",
        "\n",
        "    activations = {}\n",
        "\n",
        "    def get_activation(name):\n",
        "        def hook(module, input, output):\n",
        "            if isinstance(output, tuple):\n",
        "                output = output[0]  # Extract main tensor\n",
        "            # Debugging: Check if output is sparse\n",
        "            print(f\"Activations[{name}] type: {type(output)}, is_sparse: {output.is_sparse}\")\n",
        "            activations[name] = output.detach()\n",
        "        return hook\n",
        "\n",
        "    hooks = []\n",
        "    for layer in range(len(model.transformer.h)):\n",
        "        hook_handle = model.transformer.h[layer].register_forward_hook(\n",
        "            get_activation(f\"layer_{layer}\")\n",
        "        )\n",
        "        hooks.append(hook_handle)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        _ = model(input_ids, use_cache=False)\n",
        "\n",
        "    for hook_handle in hooks:\n",
        "        hook_handle.remove()\n",
        "\n",
        "    return activations\n",
        "\n",
        "# Function for causal tracing\n",
        "def causal_tracing(sentence, model, tokenizer, intervention_layer, control_activation, max_length):\n",
        "    input_ids = tokenizer(\n",
        "        sentence,\n",
        "        return_tensors=\"pt\",\n",
        "        padding='max_length',\n",
        "        truncation=True,\n",
        "        max_length=max_length\n",
        "    ).input_ids.to(device)\n",
        "\n",
        "    print(f\"Causal tracing input IDs shape: {input_ids.shape}\")\n",
        "\n",
        "    def modify_activation(module, input, output):\n",
        "        if module == model.transformer.h[intervention_layer]:\n",
        "            if isinstance(output, tuple):\n",
        "                hidden_states = output[0]\n",
        "                rest_outputs = output[1:]\n",
        "            else:\n",
        "                hidden_states = output\n",
        "                rest_outputs = ()\n",
        "            control_tensor = control_activation.to(hidden_states.device)\n",
        "            control_tensor = control_tensor[:, :hidden_states.size(1), :]\n",
        "\n",
        "            # Debugging: Print shapes and types\n",
        "            print(f\"Layer {intervention_layer}:\")\n",
        "            print(f\"  Hidden states shape: {hidden_states.shape}, dtype: {hidden_states.dtype}, is_sparse: {hidden_states.is_sparse}\")\n",
        "            print(f\"  Control tensor shape: {control_tensor.shape}, dtype: {control_tensor.dtype}, is_sparse: {control_tensor.is_sparse}\")\n",
        "\n",
        "            # Ensure tensors are contiguous\n",
        "            control_tensor = control_tensor.contiguous()\n",
        "            hidden_states = hidden_states.contiguous()\n",
        "\n",
        "            # Check dimensions and data types\n",
        "            if control_tensor.dim() != hidden_states.dim():\n",
        "                print(f\"Dimension mismatch: control_tensor.dim() = {control_tensor.dim()}, hidden_states.dim() = {hidden_states.dim()}\")\n",
        "                raise ValueError(\"Dimension mismatch between control_tensor and hidden_states\")\n",
        "            if control_tensor.dtype != hidden_states.dtype:\n",
        "                print(f\"Data type mismatch: control_tensor.dtype = {control_tensor.dtype}, hidden_states.dtype = {hidden_states.dtype}\")\n",
        "                control_tensor = control_tensor.type(hidden_states.dtype)\n",
        "\n",
        "            if control_tensor.shape != hidden_states.shape:\n",
        "                print(f\"Shape mismatch at layer {intervention_layer}\")\n",
        "                raise ValueError(\n",
        "                    f\"Shape mismatch: control_tensor {control_tensor.shape}, hidden_states {hidden_states.shape}\"\n",
        "                )\n",
        "\n",
        "            # Return the modified hidden states along with any additional outputs\n",
        "            return (control_tensor,) + rest_outputs\n",
        "        return output\n",
        "\n",
        "    # Register hook for the specific layer\n",
        "    hook_handle = model.transformer.h[intervention_layer].register_forward_hook(\n",
        "        modify_activation\n",
        "    )\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model(input_ids, use_cache=False)\n",
        "\n",
        "    # Remove the hook after forward pass\n",
        "    hook_handle.remove()\n",
        "\n",
        "    return outputs.logits\n",
        "\n",
        "# Select baseline and control sentences\n",
        "baseline_sentence = sql_examples[0]\n",
        "control_sentence = non_sql_examples[0]\n",
        "\n",
        "# Extract control activations\n",
        "control_activations = get_activations_for_sentence(\n",
        "    control_sentence, model, tokenizer, max_length=max_length\n",
        ")\n",
        "\n",
        "# Add random noise to control activations\n",
        "control_activations[f\"layer_{layer}\"] += torch.randn_like(control_activations[f\"layer_{layer}\"]) * 0.01\n",
        "\n",
        "\n",
        "if control_activations is None:\n",
        "    print(\"Failed to extract control activations due to tokenization error.\")\n",
        "    exit()\n",
        "\n",
        "# Get baseline logits\n",
        "try:\n",
        "    input_ids = tokenizer(\n",
        "        baseline_sentence,\n",
        "        return_tensors=\"pt\",\n",
        "        padding='max_length',\n",
        "        truncation=True,\n",
        "        max_length=max_length\n",
        "    ).input_ids.to(device)\n",
        "\n",
        "    print(f\"Baseline input_ids shape: {input_ids.shape}\")\n",
        "    print(f\"Baseline input_ids: {input_ids}\")\n",
        "    print(f\"Max token ID: {input_ids.max().item()}\")\n",
        "    print(f\"Min token ID: {input_ids.min().item()}\")\n",
        "\n",
        "    if input_ids.max() >= tokenizer.vocab_size or input_ids.min() < 0:\n",
        "        raise ValueError(\"Invalid token IDs detected in baseline input_ids.\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"Tokenization error: {e}\")\n",
        "    exit()\n",
        "\n",
        "with torch.no_grad():\n",
        "    baseline_logits = model(input_ids, use_cache=False).logits\n",
        "\n",
        "# Perform causal tracing across all layers\n",
        "layer_effects = []\n",
        "for layer in range(len(model.transformer.h)):\n",
        "    control_activation = control_activations[f'layer_{layer}']\n",
        "    intervened_logits = causal_tracing(\n",
        "        baseline_sentence, model, tokenizer, layer, control_activation, max_length\n",
        "    )\n",
        "    # Measure difference using KL divergence\n",
        "    difference = torch.nn.functional.kl_div(\n",
        "        torch.log_softmax(baseline_logits[0, -1], dim=0),\n",
        "        torch.softmax(intervened_logits[0, -1], dim=0),\n",
        "        reduction=\"batchmean\"\n",
        "    ).item()\n",
        "    layer_effects.append(difference)\n",
        "\n",
        "    # Clear cache\n",
        "    del control_activation, intervened_logits\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "# Plot the results\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(layer_effects, marker='o')\n",
        "plt.xlabel(\"Layer\")\n",
        "plt.ylabel(\"KL Divergence\")\n",
        "plt.title(\"Effect of Intervention on GPT-Neo Output\")\n",
        "plt.grid()\n",
        "plt.show()\n"
      ]
    },
